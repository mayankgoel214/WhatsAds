{
  "name": "autmn",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @autmn/api dev",
    "dev:worker": "pnpm --filter @autmn/worker dev",
    "dev": "pnpm run --parallel dev:api dev:worker",
    "build": "pnpm --filter @autmn/db build && pnpm --filter '!@autmn/db' -r build",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @autmn/db generate",
    "db:migrate": "pnpm --filter @autmn/db migrate",
    "db:push": "pnpm --filter @autmn/db push",
    "db:studio": "pnpm --filter @autmn/db studio",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "prettier": "^3.4.0"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
