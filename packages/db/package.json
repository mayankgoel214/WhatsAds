{
  "name": "@autmn/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc && node -e \"const{cpSync}=require('fs');cpSync('src/generated/client','dist/generated/client',{recursive:true,filter:src=>!src.endsWith('.ts')||src.endsWith('.d.ts')})\"",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "generate": "prisma generate",
    "postinstall": "prisma generate",
    "migrate": "prisma migrate dev",
    "push": "prisma db push",
    "studio": "prisma studio"
  },
  "dependencies": {
    "prisma": "~6.6.0",
    "@prisma/client": "~6.6.0"
  }
}
