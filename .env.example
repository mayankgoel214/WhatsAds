# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# fal.ai — BiRefNet v2 background removal only (video generation removed 2026-04-23)
FAL_KEY=

# Google AI (Gemini 2.5 Flash Lite)
GOOGLE_AI_API_KEY=
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview  # Override Gemini image generation model

# OpenAI (Tier 3 provider fallback -- gpt-image-1)
# Used only when both Gemini Pro and Flash fail. Comma-separated for rotation.
OPENAI_API_KEY=

# Groq (Whisper Turbo)
GROQ_API_KEY=

# Sarvam AI (fallback transcription)
SARVAM_API_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Upstash Redis (BullMQ)
REDIS_URL=

# Admin routes — required in production
ADMIN_SECRET=  # Required in production. Generate with: openssl rand -hex 32

# PAYMENT_BYPASS=true  # NEVER commit this. Use shell export only: export PAYMENT_BYPASS=true

# Sentry
SENTRY_DSN=

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
APP_URL=http://localhost:3000
