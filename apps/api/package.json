{
  "name": "@autmn/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm --filter '@autmn/api^...' --filter '!@autmn/db' build && tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@autmn/ai": "workspace:^",
    "@autmn/db": "workspace:*",
    "@autmn/keypool": "workspace:*",
    "@autmn/payment": "workspace:*",
    "@autmn/queue": "workspace:*",
    "@autmn/session": "workspace:*",
    "@autmn/storage": "workspace:*",
    "@autmn/whatsapp": "workspace:*",
    "@bull-board/api": "^6.0.0",
    "@bull-board/fastify": "^6.0.0",
    "@bull-board/ui": "^6.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^10.0.0",
    "@prisma/client": "~6.6.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.0.0",
    "prisma": "~6.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3"
  }
}
