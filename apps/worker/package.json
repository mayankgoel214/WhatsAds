    "@whatsads/session": "workspace:*",
    "@whatsads/storage": "workspace:*",
    "@whatsads/whatsapp": "workspace:*",
    "bullmq": "^5.0.0",
    "dotenv": "^17.3.1",
    "ioredis": "^5.4.0",
    "prisma": "~6.6.0",
    "zod": "^3.23.0"
  }
